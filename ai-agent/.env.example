# =============================================================================
# AI Agent -- environment variable reference
# Copy this file to .env and fill in the values for your chosen provider.
# All variables are prefixed with AI_AGENT_.
# =============================================================================

# -----------------------------------------------------------------------------
# Provider selection
# Options: llama_cpp | openai | anthropic | ollama | groq
# -----------------------------------------------------------------------------
AI_AGENT_PROVIDER=llama_cpp

# =============================================================================
# llama_cpp  (default)
#
# Loads the GGUF model IN-PROCESS -- no HTTP server required.
# The model is loaded once at startup and kept in memory.
#
# chat_format is CRITICAL for tool calling (from benchmarks):
#   "chatml-function-calling" -- LFM2.5, Qwen2.5, Phi-4-mini, most models
#   "llama-3"                 -- Llama 3.x models
#   (leave blank to let llama-cpp autodetect -- ok for text, unreliable for tools)
#
# n_gpu_layers=-1 offloads all layers to GPU (fastest).
# n_gpu_layers=0  runs on CPU only.
# =============================================================================
AI_AGENT_LLAMA_CPP__MODEL_PATH=C:/Users/Eduardo/Documents/Github/app-tfg/benchmarks/models/LFM2.5-1.2B-Instruct-Q4_0.gguf
AI_AGENT_LLAMA_CPP__CHAT_FORMAT=chatml-function-calling
AI_AGENT_LLAMA_CPP__N_GPU_LAYERS=-1
AI_AGENT_LLAMA_CPP__N_CTX=4096
AI_AGENT_LLAMA_CPP__VERBOSE=false

# =============================================================================
# openai
# =============================================================================
# AI_AGENT_PROVIDER=openai
# AI_AGENT_OPENAI__API_KEY=sk-...
# AI_AGENT_OPENAI__MODEL=gpt-4o-mini
# AI_AGENT_OPENAI__BASE_URL=          # leave blank for api.openai.com

# =============================================================================
# anthropic
# =============================================================================
# AI_AGENT_PROVIDER=anthropic
# AI_AGENT_ANTHROPIC__API_KEY=sk-ant-...
# AI_AGENT_ANTHROPIC__MODEL=claude-3-5-haiku-20241022

# =============================================================================
# ollama  (local Ollama server, OpenAI-compatible)
# Start with: ollama serve
# =============================================================================
# AI_AGENT_PROVIDER=ollama
# AI_AGENT_OLLAMA__BASE_URL=http://localhost:11434/v1
# AI_AGENT_OLLAMA__MODEL=llama3.2

# =============================================================================
# groq
# =============================================================================
# AI_AGENT_PROVIDER=groq
# AI_AGENT_GROQ__API_KEY=gsk_...
# AI_AGENT_GROQ__MODEL=llama-3.1-8b-instant
